{
  "name": "AppSettings",
  "type": "object",
  "properties": {
    "key": {
      "type": "string",
      "description": "Chave da configura\u00e7\u00e3o"
    },
    "value": {
      "type": "string",
      "description": "Valor da configura\u00e7\u00e3o"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
